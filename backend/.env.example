DATABASE_URL=postgresql://daytona:daytona@localhost:5432/agentos

# --- LLM provider selection (priority: Anthropic > NVIDIA > offline mock) ---

# Option A: Anthropic / Claude (native)
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# Option B: NVIDIA NIM (OpenAI-compatible; hosts Llama / Nemotron, NOT Claude)
# NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# If neither key is set, agents run in deterministic offline MOCK mode.
